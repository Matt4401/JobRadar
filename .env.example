MYSQL_ROOT_PASSWORD=[rootPassword]
MYSQL_DATABASE=jobradar

# Non-root users (created by db/docker/initdb/01-create-users.sh).
JOBRADAR_APP_USER=jobradar_app
JOBRADAR_APP_PASSWORD=[appPassword]
JOBRADAR_MIGRATOR_USER=jobradar_migrator
JOBRADAR_MIGRATOR_PASSWORD=[migratorPassword]

# Connection strings used by the Rust code.
# DATABASE_URL : app user (DML only), used by the API and scraper.
# MIGRATION_DATABASE_URL : migrator user (DML + DDL), used by the migration CLI.
DATABASE_URL=mysql://jobradar_app:[appPassword]@localhost:3306/jobradar
MIGRATION_DATABASE_URL=mysql://jobradar_migrator:[migratorPassword]@localhost:3306/jobradar

# If you want to use this .env template as-is, you will have to 
# replace the placeholders above with actual passwords.
